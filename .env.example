# Copy this file to .env.local for local development.
# Keep real credentials in .env.local, Vercel, or GitHub environment secrets.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/abide"
APP_TIME_ZONE="Europe/London"

# Single-user login for the public app. Use real private values in deployment.
ABIDE_AUTH_USERNAME="your-username"
ABIDE_AUTH_PASSWORD="replace-with-a-long-password"
ABIDE_SESSION_SECRET="replace-with-a-random-32-byte-secret"
